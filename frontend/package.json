{
  "name": "get-space-front",
  "productName": "Get Space",
  "version": "1.0.0",
  "description": "A high-performance Windows file system analyzer built for speed.",
  "author": "Michał Wierzbiński github.com/vende11s",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.vende11s.getspace",
    "compression": "normal",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/logo.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Get Space",
      "uninstallDisplayName": "Get Space (Uninstall)"
    },
    "extraFiles": [
      {
        "from": "getSpace-backend.exe",
        "to": ".",
        "filter": ["**/*"]
      }
    ]
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^24.13.3"
  }
}